---
const base = import.meta.env.BASE_URL.replace(/\/$/, "")
const redirectUrl = `${base}/en/`
const site = "https://kaizencode-sl.github.io"
const canonicalUrl = `${site}${redirectUrl}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={`${site}${base}/es/`} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <title>Kaizencode — Software & E-Commerce Solutions</title>
  </head>
  <body></body>
</html>
