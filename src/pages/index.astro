---
const redirectUrl = "/en/"
const site = "https://www.kaizencode.es"
const canonicalUrl = `${site}${redirectUrl}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={`${site}/es/`} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <title>Kaizencode - software & e-commerce solutions</title>
    <meta
      name="description"
      content="Software & e-commerce studio building custom solutions, beautiful websites, and scalable e-commerce platforms."
    />
    <meta
      property="og:title"
      content="Kaizencode - software & e-commerce solutions"
    />
    <meta
      property="og:description"
      content="Software & e-commerce studio building custom solutions, beautiful websites, and scalable e-commerce platforms."
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Kaizencode" />
  </head>
  <body>
    <p><a href={redirectUrl}>Redirecting to English site...</a></p>
  </body>
</html>
